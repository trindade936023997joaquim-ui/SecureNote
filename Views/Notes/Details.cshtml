@model SecureNotes.Models.Note

@{
    ViewData["Title"] = "Detalhes da Nota";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    :root {
        --bg-dark: #020617;
        --card-dark: #0f172a;
        --accent-blue: #38bdf8;
        --accent-purple: #818cf8;
        --text-milk: #f8fafc;
        --text-muted: #94a3b8;
    }

    body {
        background: var(--bg-dark);
        color: var(--text-milk);
        font-family: 'Inter', system-ui, sans-serif;
    }

    .bg-glow {
        position: fixed;
        top: 0; left: 0;
        width: 100%; height: 100%;
        background:
            radial-gradient(circle at 20% 30%, rgba(56,189,248,0.08), transparent 40%),
            radial-gradient(circle at 80% 70%, rgba(129,140,248,0.08), transparent 40%);
        z-index: -1;
    }

    .note-card {
        max-width: 800px;
        margin: auto;
        padding: 35px;
        border-radius: 28px;
        background: linear-gradient(145deg, rgba(15,23,42,0.85), rgba(2,6,23,0.95));
        border: 1px solid rgba(255,255,255,0.06);
        box-shadow: 0 25px 50px rgba(0,0,0,0.5);
        backdrop-filter: blur(15px);
    }

    .title {
        font-size: 2rem;
        font-weight: 800;
        margin-bottom: 10px;
    }

    .label {
        font-weight: 700;
        color: var(--accent-blue);
        margin-top: 20px;
        display: block;
    }

    .content-box {
        margin-top: 10px;
        padding: 18px;
        border-radius: 14px;
        background: rgba(15,23,42,0.6);
        border: 1px solid rgba(255,255,255,0.08);
        white-space: pre-wrap;
    }

    .btn-group-custom {
        margin-top: 25px;
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
    }

    .btn-main {
        background: linear-gradient(90deg, var(--accent-blue), var(--accent-purple));
        border: none;
        padding: 12px 20px;
        border-radius: 14px;
        font-weight: 700;
        color: #020617;
        text-decoration: none;
        transition: 0.3s;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .btn-main:hover {
        transform: translateY(-3px);
        filter: brightness(1.1);
    }

    .btn-secondary {
        padding: 12px 20px;
        border-radius: 14px;
        border: 1px solid rgba(255,255,255,0.15);
        color: var(--text-milk);
        text-decoration: none;
        transition: 0.3s;
    }

    .btn-secondary:hover {
        border-color: var(--accent-blue);
        color: var(--accent-blue);
    }
</style>

<div class="bg-glow"></div>

<div class="container py-5 animate__animated animate__fadeInUp">

    <div class="note-card">

        <h2 class="title">
            <i class="bi bi-journal-text me-2 text-info"></i>
            @Model.Title
        </h2>

        <span class="label">Conteúdo da Nota</span>

        <div class="content-box">
            @Model.Content
        </div>

        <div class="btn-group-custom">

            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-main">
                <i class="bi bi-pencil-square"></i> Editar
            </a>

            <a asp-action="Index" class="btn-secondary">
                <i class="bi bi-arrow-left"></i> Voltar
            </a>

        </div>

    </div>

</div>