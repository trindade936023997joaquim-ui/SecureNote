@model SecureNotes.Models.Note

@{
    ViewData["Title"] = "Apagar Nota";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    :root {
        --bg-dark: #020617;
        --card-dark: #0f172a;
        --accent-blue: #38bdf8;
        --danger-red: #f87171;
        --text-milk: #f8fafc;
        --text-muted: #94a3b8;
    }

    body {
        background: var(--bg-dark);
        color: var(--text-milk);
        font-family: 'Inter', system-ui, sans-serif;
    }

    .bg-glow {
        position: fixed;
        inset: 0;
        background:
            radial-gradient(circle at 20% 30%, rgba(248,113,113,0.08), transparent 40%),
            radial-gradient(circle at 80% 70%, rgba(56,189,248,0.08), transparent 40%);
        z-index: -1;
    }

    .delete-card {
        max-width: 550px;
        margin: auto;
        padding: 35px;
        border-radius: 28px;
        background: linear-gradient(145deg, rgba(15,23,42,0.85), rgba(2,6,23,0.95));
        border: 1px solid rgba(255,255,255,0.06);
        box-shadow: 0 25px 50px rgba(0,0,0,0.5);
        backdrop-filter: blur(15px);
        text-align: center;
    }

    .icon-danger {
        font-size: 3rem;
        color: var(--danger-red);
        margin-bottom: 15px;
    }

    .title {
        font-size: 1.8rem;
        font-weight: 800;
        margin-bottom: 10px;
    }

    .subtitle {
        color: var(--text-muted);
        margin-bottom: 20px;
    }

    .note-preview {
        background: rgba(15,23,42,0.6);
        border: 1px solid rgba(255,255,255,0.08);
        padding: 15px;
        border-radius: 14px;
        margin-bottom: 25px;
        font-weight: 600;
    }

    .btn-danger-custom {
        background: linear-gradient(90deg, #ef4444, #f87171);
        border: none;
        padding: 12px 20px;
        border-radius: 14px;
        font-weight: 700;
        color: white;
        width: 100%;
        margin-bottom: 10px;
        transition: 0.3s;
    }

    .btn-danger-custom:hover {
        transform: translateY(-2px);
        filter: brightness(1.1);
    }

    .btn-cancel {
        display: inline-block;
        margin-top: 10px;
        color: var(--text-muted);
        text-decoration: none;
        transition: 0.3s;
    }

    .btn-cancel:hover {
        color: var(--accent-blue);
    }
</style>

<div class="bg-glow"></div>

<div class="container py-5">

    <div class="delete-card">

        <i class="bi bi-exclamation-triangle-fill icon-danger"></i>

        <h2 class="title">Apagar Nota</h2>
        <p class="subtitle">
            Esta ação é <strong>irreversível</strong>. Tens certeza que queres continuar?
        </p>

        <div class="note-preview">
            @Model.Title
        </div>

        <form asp-action="Delete" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <button type="submit" class="btn-danger-custom">
                <i class="bi bi-trash3 me-2"></i> Sim, apagar
            </button>
        </form>

        <a asp-action="Index" class="btn-cancel">
            ← Cancelar
        </a>

    </div>

</div>