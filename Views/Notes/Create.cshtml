@model SecureNotes.Models.Note

@{
    ViewData["Title"] = "Nova Nota Segura";
}

<style>
    /* (mantém TODO o teu CSS igual — não alterei nada) */
    .create-card {
        background: rgba(15, 23, 42, 0.6);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 24px;
        padding: 2.5rem;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
        max-width: 800px;
        margin: 2rem auto;
    }

    .form-group-custom { margin-bottom: 1.5rem; }

    .label-custom {
        display: block;
        color: var(--accent-blue);
        font-weight: 600;
        margin-bottom: 0.5rem;
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .input-custom {
        width: 100%;
        background: rgba(2, 6, 23, 0.5);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 12px;
        padding: 12px 16px;
        color: var(--text-milk) !important;
    }

    textarea.input-custom {
        min-height: 200px;
    }

    .btn-save {
        background: linear-gradient(90deg, var(--accent-blue), #818cf8);
        border: none;
        padding: 14px 30px;
        border-radius: 12px;
        font-weight: 800;
        width: 100%;
    }
</style>

<div class="container animate__animated animate__fadeIn">
    
    <div class="create-card">

        <h2 class="fw-bold mb-4">Nova Nota Encriptada</h2>

        <form asp-action="Create" method="post">

            <!-- 🔐 PROTEÇÃO CSRF -->
            @Html.AntiForgeryToken()

            <!-- ❗ ERROS -->
            <div asp-validation-summary="All" class="text-danger small mb-3"></div>

            <div class="form-group-custom">
                <label asp-for="Title" class="label-custom"></label>
                <input asp-for="Title" class="input-custom" />
                <span asp-validation-for="Title" class="text-danger small"></span>
            </div>

            <div class="form-group-custom">
                <label asp-for="Content" class="label-custom"></label>
                <textarea asp-for="Content" class="input-custom"></textarea>
                <span asp-validation-for="Content" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn-save">
                Guardar Nota
            </button>

        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}