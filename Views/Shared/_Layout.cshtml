<!DOCTYPE html>
<html lang="pt-ao">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SecureNotes</title>

    <!-- BOOTSTRAP -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- ICONS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <!-- FONT -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap" rel="stylesheet">

    <style>
        :root {
            --bg-dark: #020617;
            --card-dark: #0f172a;
            --text-milk: #f8fafc;
            --accent-blue: #38bdf8;
        }

        body {
            background: var(--bg-dark);
            color: var(--text-milk);
            font-family: 'Inter', sans-serif;
        }

        .navbar-custom {
            background: rgba(2, 6, 23, 0.85);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(255,255,255,0.05);
        }

        .navbar-brand-custom {
            font-weight: 800;
            color: white !important;
        }

        /* USER BUTTON */
        .profile-pill {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 6px 12px;
            border-radius: 50px;
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            cursor: pointer;
            text-decoration: none;
            color: white;
        }

        .profile-pill:hover {
            border-color: var(--accent-blue);
            background: rgba(56, 189, 248, 0.1);
        }

        .dropdown-menu-dark {
            background: var(--card-dark);
            border: 1px solid rgba(255,255,255,0.1);
        }

        .dropdown-item {
            color: white;
        }

        .dropdown-item:hover {
            background: rgba(56, 189, 248, 0.1);
            color: var(--accent-blue);
        }
        .bg-glow {
            position: fixed;
            top: 0; left: 0;
            width: 100%; height: 100%;
            z-index: -1;
            pointer-events: none;
        }
        .dropdown-menu li {
    width: 100%;
}

.dropdown-item {
    display: block;
    width: 100%;
    cursor: pointer;
}

.dropdown-item {
    cursor: pointer !important;
}
    </style>
</head>

<body>

            <header>
                <nav class="navbar navbar-expand-md navbar-custom">
                    <div class="container">

                        <!-- LOGO -->
                        <a class="navbar-brand navbar-brand-custom"
                        asp-controller="Home"
                        asp-action="Index">
                            SECURE<span style="color: var(--accent-blue)">NOTES</span>
                        </a>

                        <div class="ms-auto d-flex align-items-center gap-3">

                            @if (User.Identity != null && User.Identity.IsAuthenticated)
                            {
                                <!-- 🔐 USER DROPDOWN -->
                                <div class="dropdown">

                <button class="btn btn-outline-light dropdown-toggle px-3 py-2 fw-bold"
                        type="button"
                        data-bs-toggle="dropdown"
                        aria-expanded="false"
                        style="border-radius: 12px;">

                    <i class="bi bi-person-circle me-1"></i> Utilizador
                </button>

                <ul class="dropdown-menu dropdown-menu-dark shadow-lg">

                <li>
                    <a class="dropdown-item"
                    asp-controller="User"
                    asp-action="Index">
                        <i class="bi bi-person me-2"></i> Meu Perfil
                    </a>
                </li>

                <li>
                    <a class="dropdown-item"
                    asp-controller="User"
                    asp-action="Security">
                        <i class="bi bi-shield-lock me-2"></i> Segurança
                    </a>
                </li>

                <li><hr class="dropdown-divider"></li>

                <!-- LOGOUT CORRETO -->
                <li>
                    <a href="#"
                    class="dropdown-item text-danger"
                    onclick="event.preventDefault(); document.getElementById('logoutForm').submit();">

                        <i class="bi bi-box-arrow-right me-2"></i> Sair
                    </a>
                </li>

            </ul>

            <!-- FORM FORA DO UL (IMPORTANTE) -->
            <form id="logoutForm"
                asp-area="Identity"
                asp-page="/Account/Logout"
                method="post"
                style="display:none;">
                @Html.AntiForgeryToken()
            </form>

</div>
                }
                else
                {
                    <!-- 🔓 LOGIN BUTTON -->
                    <a asp-area="Identity"
                       asp-page="/Account/Login"
                       class="btn btn-outline-light fw-bold px-3"
                       style="border-radius: 12px;">
                        <i class="bi bi-box-arrow-in-right me-1"></i>
                        Login
                    </a>
                }

            </div>

        </div>
    </nav>
</header>

<main class="container mt-4">
    @RenderBody()
</main>

<!-- BOOTSTRAP JS (OBRIGATÓRIO PARA DROPDOWN) -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

@RenderSection("Scripts", required: false)
<script>
    console.log("JS ativo");
</script>
</body>

</html>