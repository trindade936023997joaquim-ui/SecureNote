@model SecureNotes.Models.Note

@{
    ViewData["Title"] = "Editar Nota";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    :root {
        --bg-dark: #020617;
        --card-dark: #0f172a;
        --accent-blue: #38bdf8;
        --accent-purple: #818cf8;
        --text-milk: #f8fafc;
        --text-muted: #94a3b8;
    }

    body {
        background: var(--bg-dark);
        color: var(--text-milk);
        font-family: 'Inter', system-ui, sans-serif;
    }

    .bg-glow {
        position: fixed;
        top: 0; left: 0;
        width: 100%; height: 100%;
        background:
            radial-gradient(circle at 20% 30%, rgba(56,189,248,0.08), transparent 40%),
            radial-gradient(circle at 80% 70%, rgba(129,140,248,0.08), transparent 40%);
        z-index: -1;
    }

    .edit-card {
        background: linear-gradient(145deg, rgba(15,23,42,0.85), rgba(2,6,23,0.95));
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: 28px;
        padding: 35px;
        max-width: 650px;
        margin: auto;
        box-shadow: 0 25px 50px rgba(0,0,0,0.5);
        backdrop-filter: blur(15px);
    }

    .title {
        font-weight: 800;
        font-size: 2rem;
        margin-bottom: 5px;
    }

    .subtitle {
        color: var(--text-muted);
        font-size: 0.95rem;
        margin-bottom: 25px;
    }

    .form-control {
        background: rgba(15,23,42,0.6);
        border: 1px solid rgba(255,255,255,0.08);
        color: var(--text-milk);
        border-radius: 14px;
        padding: 12px;
        transition: 0.3s;
    }

    .form-control:focus {
        border-color: var(--accent-blue);
        box-shadow: 0 0 0 3px rgba(56,189,248,0.2);
        background: rgba(15,23,42,0.8);
        color: white;
    }

    textarea {
        min-height: 160px;
        resize: vertical;
    }

    label {
        font-weight: 600;
        margin-bottom: 6px;
        color: var(--text-milk);
    }

    .btn-main {
        width: 100%;
        margin-top: 15px;
        background: linear-gradient(90deg, var(--accent-blue), var(--accent-purple));
        border: none;
        padding: 14px;
        border-radius: 16px;
        font-weight: 800;
        color: #020617;
        transition: 0.3s;
    }

    .btn-main:hover {
        transform: translateY(-3px);
        filter: brightness(1.1);
    }

    .btn-back {
        display: inline-block;
        margin-top: 15px;
        color: var(--text-muted);
        text-decoration: none;
    }

    .btn-back:hover {
        color: var(--accent-blue);
    }

    .validation-summary {
        font-size: 13px;
        margin-bottom: 10px;
    }
</style>

<div class="bg-glow"></div>

<div class="container py-5 animate__animated animate__fadeInUp">

    <div class="edit-card">

        <h2 class="title">Editar Nota</h2>
        <p class="subtitle">Atualize o conteúdo da sua nota com segurança</p>

        <form asp-action="Edit" method="post">

            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div asp-validation-summary="All" class="text-danger validation-summary"></div>

            <div class="mb-3">
                <label asp-for="Title"></label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Content"></label>
                <textarea asp-for="Content" class="form-control"></textarea>
                <span asp-validation-for="Content" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn-main">
                <i class="bi bi-check-circle me-2"></i> Atualizar Nota
            </button>

        </form>

        <a asp-action="Index" class="btn-back">
            ← Voltar
        </a>

    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}