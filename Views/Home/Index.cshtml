@{
    ViewData["Title"] = "Secure Dashboard";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">


<style>
    :root {
        --bg-dark: #020617;
        --card-dark: #0f172a;
        --accent-blue: #38bdf8;
        --accent-purple: #818cf8;
        --text-milk: #f8fae2;
        --text-muted: #94a3b8;
    }

    body {
        background-color: var(--bg-dark) !important;
        color: var(--text-milk) !important;
        overflow-x: hidden;
        font-family: 'Inter', system-ui, sans-serif;
    }

    /* Cores de Leite para Visibilidade */
    h1, h2, h3, h4, p, span, a, label { color: var(--text-milk) !important; }
    .text-muted { color: var(--text-muted) !important; }

    /* Fundo Animado Sutil - Mais Profundo */
    .bg-glow {
        position: fixed;
        top: 0; left: 0; width: 100%; height: 100%;
        background: 
            radial-gradient(circle at 20% 30%, rgba(56, 189, 248, 0.08), transparent 40%),
            radial-gradient(circle at 80% 70%, rgba(129, 140, 248, 0.08), transparent 40%);
        z-index: -1;
        pointer-events: none;
    }

    /* Efeito de Pulso no Escudo Melhorado */
    .pulse-shield {
        animation: pulse-blue 2s infinite;
        background: rgba(56, 189, 248, 0.1);
        border-radius: 50%;
        display: inline-flex;
        padding: 20px;
    }

    @@keyframes pulse-blue {
        0% { box-shadow: 0 0 0 0 rgba(56, 189, 248, 0.4); transform: scale(1); }
        70% { box-shadow: 0 0 0 30px rgba(56, 189, 248, 0); transform: scale(1.05); }
        100% { box-shadow: 0 0 0 0 rgba(56, 189, 248, 0); transform: scale(1); }
    }

    /* Card de Boas-vindas Premium */
    .welcome-card {
        background: linear-gradient(145deg, rgba(15, 23, 42, 0.8), rgba(2, 6, 23, 0.9));
        backdrop-filter: blur(15px);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 35px;
        padding: 4.5rem 2rem;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    }

    /* Botão Principal com Efeito de Brilho */
    .btn-main {
        background: linear-gradient(90deg, var(--accent-blue), var(--accent-purple));
        color: #020617 !important;
        border: none;
        padding: 18px 40px;
        border-radius: 18px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 12px;
        box-shadow: 0 10px 20px rgba(56, 189, 248, 0.2);
    }

    .btn-main:hover {
        transform: translateY(-5px) scale(1.02);
        box-shadow: 0 20px 40px rgba(56, 189, 248, 0.4);
        filter: brightness(1.1);
    }

    /* Cards de Estatísticas Modernos */
    .stat-box {
        background: var(--card-dark);
        border-radius: 24px;
        border: 1px solid rgba(255, 255, 255, 0.05);
        padding: 25px;
        transition: all 0.4s ease;
        position: relative;
        overflow: hidden;
    }

    .stat-box::before {
        content: "";
        position: absolute;
        top: 0; left: 0; width: 100%; height: 4px;
        background: linear-gradient(90deg, var(--accent-blue), transparent);
        opacity: 0;
        transition: opacity 0.3s;
    }

    .stat-box:hover {
        background: #1e293b;
        border-color: rgba(56, 189, 248, 0.3);
        transform: translateY(-12px);
    }

    .stat-box:hover::before { opacity: 1; }

    /* Links de Navegação com Underline Animado */
    .nav-link-custom {
        position: relative;
        text-decoration: none;
        transition: color 0.3s;
    }

    .nav-link-custom::after {
        content: '';
        position: absolute;
        width: 0; height: 2px;
        bottom: -5px; left: 0;
        background-color: var(--accent-blue);
        transition: width 0.3s;
    }
    .btn-cofre {
    border: 2px solid white;
    color: white;
    border-radius: 18px;
    padding: 14px 30px;
    font-weight: bold;
    transition: all 0.3s ease;
}

.btn-cofre:hover {
    background: gray;
    color: #020617;
    transform: translateY(-3px);
}

    .nav-link-custom:hover::after { width: 100%; }
    .nav-link-custom:hover { color: var(--accent-blue) !important; }

</style>

<div class="bg-glow"></div>

<div class="container py-5">
    
    <header class="d-flex justify-content-between align-items-center mb-5 animate__animated animate__fadeInDown">
        <div class="d-flex align-items-center gap-3">
            <div class="bg-primary p-2 rounded-3 d-flex align-items-center justify-content-center" style="width: 45px; height: 45px;">
                 <i class="bi bi-shield-check text-white fs-4"></i>
            </div>
            <div>
                <h2 class="fw-bold m-0 tracking-tight" style="font-size: 1.5rem;">SECURE<span style="color: var(--accent-blue)">NOTES</span></h2>
                <div class="d-flex align-items-center gap-2">
                    <span class="badge bg-success border border-success-subtle text-white p-1 px-2" style="font-size: 0.6rem;">
                        <i class="bi bi-circle-fill animate__animated animate__flash animate__infinite" style="font-size: 0.5rem;"></i> ONLINE
                    </span>
                </div>
            </div>
        </div>        
    </header>

    <div class="welcome-card text-center animate__animated animate__zoomIn">
        <div class="mb-4 d-inline-block">
            <div class="pulse-shield">
                <i class="bi bi-incognito text-info" style="font-size: 3.5rem;"></i>
            </div>
        </div>
        
        <h1 class="display-3 fw-bold mb-3 animate__animated animate__fadeInUp animate__delay-1s">
            Notas Seguras, <br class="d-md-none"> Mente <span style="color: var(--accent-blue)">Tranquila.</span>
        </h1>
        
        <p class="lead text-muted mb-5 animate__animated animate__fadeInUp animate__delay-1s mx-auto" style="max-width: 650px;">
            A sua privacidade não é negociável. Guarde palavras-passe, chaves de API e segredos com criptografia que só você pode abrir.
        </p>
        <div class="d-flex flex-column flex-sm-row justify-content-center gap-4 animate__animated animate__fadeInUp animate__delay-2s">
     
          

            <a asp-controller="Notes" asp-action="Create" class="btn-main">
                <i class="bi bi-plus-square-fill"></i> Criar Nota Segura
            </a>

         <a asp-controller="Notes" asp-action="Index" class="btn-cofre">
            <i class="bi bi-collection-fill me-2"></i> Explorar Cofre
        </a>
        </div>
    </div>

    <div class="row g-4 mt-5">
        <div class="col-6 col-md-3 animate__animated animate__fadeInUp animate__delay-2s">
            <div class="stat-box">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <i class="bi bi-shield-shaded fs-3 text-info"></i>
                    <span class="badge rounded-pill bg-info text-dark">SSL</span>
                </div>
                <h4 class="fw-bold mb-1">E2EE</h4>
                <p class="text-muted small m-0">End-to-End Encryption</p>
            </div>
        </div>
        <div class="col-6 col-md-3 animate__animated animate__fadeInUp animate__delay-2s" style="animation-delay: 2.2s">
            <div class="stat-box">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <i class="bi bi-database-fill-lock fs-3 text-purple" style="color: var(--accent-purple)"></i>
                </div>
                <h4 class="fw-bold mb-1">SQL-Crypt</h4>
                <p class="text-muted small m-0">Base de Dados Protegida</p>
            </div>
        </div>
        <div class="col-6 col-md-3 animate__animated animate__fadeInUp animate__delay-2s" style="animation-delay: 2.4s">
            <div class="stat-box">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <i class="bi bi-phone-vibrate fs-3 text-warning"></i>
                </div>
                <h4 class="fw-bold mb-1">Mobile</h4>
                <p class="text-muted small m-0">100% Responsivo</p>
            </div>
        </div>
        <div class="col-6 col-md-3 animate__animated animate__fadeInUp animate__delay-2s" style="animation-delay: 2.6s">
            <div class="stat-box">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <i class="bi bi-lightning-charge-fill fs-3 text-success"></i>
                </div>
                <h4 class="fw-bold mb-1">Fast</h4>
                <p class="text-muted small m-0">Acesso Instantâneo</p>
            </div>
        </div>
    </div>
</div>